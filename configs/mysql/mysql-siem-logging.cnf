# MySQL SIEM logging configuration snippet
# Place under [mysqld] section or include from the main MySQL configuration.

[mysqld]
general_log = 1
general_log_file = /var/log/mysql/mysql.log
log_output = FILE

slow_query_log = 1
slow_query_log_file = /var/log/mysql/mysql-slow.log
long_query_time = 2
log_queries_not_using_indexes = 0

log_error = /var/log/mysql/error.log
